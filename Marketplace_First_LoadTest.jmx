                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&quot;service&quot;:{&quot;name&quot;: &quot;Performance_${__time(HHmmss)}&quot;,&quot;name_ar&quot;:&quot;Performance_${__time(HHmmss)}&quot;,&quot;description&quot;:&quot;Performance&quot;,&quot;description_ar&quot;:&quot;Performance&quot;},&quot;parameters&quot;:[{&quot;id&quot;:&quot;${__RandomString(19,abcdefghijklmnopqrstuvwxyz0123456789)}&quot;,&quot;type&quot;:&quot;text&quot;,&quot;label&quot;:&quot;Performance &quot;,&quot;label_ar&quot;:&quot;Performance &quot;,&quot;placeholder&quot;:&quot;&quot;,&quot;required&quot;:true,&quot;width&quot;:&quot;1/2&quot;,&quot;is_visible&quot;:true}],&quot;deliverables&quot;:[{&quot;id&quot;:&quot;${__RandomString(19,abcdefghijklmnopqrstuvwxyz0123456789)}&quot;,&quot;type&quot;:&quot;text&quot;,&quot;label&quot;:&quot;Performance &quot;,&quot;label_ar&quot;:&quot;Performance &quot;,&quot;placeholder&quot;:&quot;&quot;,&quot;required&quot;:true,&quot;width&quot;:&quot;1/2&quot;,&quot;description&quot;:&quot;&quot;}],&quot;fees&quot;:{&quot;type&quot;:&quot;fixed&quot;,&quot;fixed_amount&quot;:1}}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
